<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ragproject.ragserver.mapper.KnowledgeItemMapper">

    <resultMap id="KnowledgeItemResultMap" type="com.ragproject.ragserver.model.KnowledgeItem">
        <id property="knowledgeId" column="knowledge_id"/>
        <result property="documentId" column="document_id"/>
        <result property="question" column="question"/>
        <result property="answer" column="answer"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findActiveItems" resultMap="KnowledgeItemResultMap">
        SELECT knowledge_id, document_id, question, answer, status, created_at, updated_at
        FROM t_knowledge_item
        WHERE status = 1
        ORDER BY knowledge_id ASC
    </select>

    <insert id="insert" parameterType="com.ragproject.ragserver.model.KnowledgeItem" useGeneratedKeys="true" keyProperty="knowledgeId">
        INSERT INTO t_knowledge_item (document_id, question, answer, status)
        VALUES (#{documentId}, #{question}, #{answer}, #{status})
    </insert>

    <insert id="insertBatch">
        INSERT INTO t_knowledge_item (document_id, question, answer, status)
        VALUES
        <foreach collection="items" item="item" separator=",">
            (#{item.documentId}, #{item.question}, #{item.answer}, #{item.status})
        </foreach>
    </insert>

    <delete id="deleteByDocumentId">
        DELETE FROM t_knowledge_item
        WHERE document_id = #{documentId}
    </delete>

</mapper>
