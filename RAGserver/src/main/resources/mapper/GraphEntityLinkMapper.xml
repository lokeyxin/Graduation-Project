<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ragproject.ragserver.mapper.GraphEntityLinkMapper">

    <resultMap id="GraphEntityLinkResultMap" type="com.ragproject.ragserver.model.GraphEntityLink">
        <id property="id" column="id"/>
        <result property="documentId" column="document_id"/>
        <result property="knowledgeId" column="knowledge_id"/>
        <result property="graphNodeId" column="graph_node_id"/>
        <result property="entityName" column="entity_name"/>
        <result property="entityType" column="entity_type"/>
        <result property="sourceChunkNo" column="source_chunk_no"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insertBatch">
        INSERT IGNORE INTO t_graph_entity_link
        (document_id, knowledge_id, graph_node_id, entity_name, entity_type, source_chunk_no)
        VALUES
        <foreach collection="items" item="item" separator=",">
            (#{item.documentId}, #{item.knowledgeId}, #{item.graphNodeId}, #{item.entityName}, #{item.entityType}, #{item.sourceChunkNo})
        </foreach>
    </insert>

    <delete id="deleteByDocumentId">
        DELETE FROM t_graph_entity_link
        WHERE document_id = #{documentId}
    </delete>

    <select id="findByGraphNodeIds" resultMap="GraphEntityLinkResultMap">
        SELECT id, document_id, knowledge_id, graph_node_id, entity_name, entity_type, source_chunk_no, created_at
        FROM t_graph_entity_link
        WHERE graph_node_id IN
        <foreach collection="graphNodeIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <select id="findDistinctKnowledgeIdsByGraphNodeIds" resultType="long">
        SELECT DISTINCT knowledge_id
        FROM t_graph_entity_link
        WHERE graph_node_id IN
        <foreach collection="graphNodeIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        ORDER BY knowledge_id ASC
    </select>

    <select id="findDistinctDocumentIdsByKnowledgeIds" resultType="long">
        SELECT DISTINCT document_id
        FROM t_graph_entity_link
        WHERE knowledge_id IN
        <foreach collection="knowledgeIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        ORDER BY document_id ASC
    </select>

</mapper>
